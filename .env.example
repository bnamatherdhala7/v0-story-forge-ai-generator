# OpenAI — required for script generation
OPENAI_API_KEY=sk-...

# App URL — required in production (Vercel sets this automatically on most plans)
# For local dev, leave unset (defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# n8n webhook — optional, used for validation + logging
N8N_WEBHOOK_URL=https://your-n8n-instance.app.n8n.cloud/webhook/storyforge-generate

# Upstash Redis — required for production job storage
# Create a free database at https://console.upstash.com
# Without this, the in-memory store is used (fine for local dev, breaks on Vercel)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Creatomate — required for v0.3 real video rendering
# https://creatomate.com/docs/api/introduction
CREATOMATE_API_KEY=your-key
